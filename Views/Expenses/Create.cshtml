@model AdminPanel.Models.Expense

@{
    ViewData["Title"] = "Tilføj udgift";
}

<h2>Tilføj Udgift</h2>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label asp-for="Produkt"></label>
        <input asp-for="Produkt" class="form-control" />
        <span asp-validation-for="Produkt" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Dato"></label>
        <input asp-for="Dato" type="date" class="form-control" />
        <span asp-validation-for="Dato" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Antal"></label>
        <input asp-for="Antal" class="form-control" />
        <span asp-validation-for="Antal" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="PrisPrStk"></label>
        <input asp-for="PrisPrStk" class="form-control" />
        <span asp-validation-for="PrisPrStk" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Noter"></label>
        <input asp-for="Noter" class="form-control" />
        <span asp-validation-for="Noter" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}