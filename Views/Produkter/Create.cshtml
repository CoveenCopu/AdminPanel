@model AdminPanel.Models.Produkt
@{
    ViewData["Title"] = "Tilføj produkt";
}

<h2>Tilføj produkt</h2>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label asp-for="Navn"></label>
        <input asp-for="Navn" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Pris"></label>
        <input asp-for="Pris" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Info"></label>
        <input asp-for="Info" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Gem</button>
    <a asp-action="Index" class="btn btn-secondary">Annuller</a>
</form>