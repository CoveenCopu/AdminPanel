@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Login</title>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
        import {
            getAuth,
            signInWithEmailAndPassword
        } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js";

                const firebaseConfig = {
          apiKey: "AIzaSyBMB5DYI6XtVPrw-GSHD0h6j3qjdNQMq4E",
          authDomain: "ms-admin---final.firebaseapp.com",
          projectId: "ms-admin---final",
          storageBucket: "ms-admin---final.firebasestorage.app",
          messagingSenderId: "371213449710",
          appId: "1:371213449710:web:756fd8d276f41b05b236ff"
        };

        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);

        window.login = async function () {
            const email = document.getElementById("email").value;
            const password = document.getElementById("password").value;

            try {
                const userCredential = await signInWithEmailAndPassword(
                    auth,
                    email,
                    password
                );

                const user = userCredential.user;
                const idToken = await user.getIdToken();

                const response = await fetch("/Account/Login", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        idToken: idToken
                    })
                });

                if (response.ok) {
                    window.location.href = "/";
                } else {
                    alert("Login failed");
                }
            }
            catch (error) {
                console.error(error);
                alert("Forkert email eller password");
            }
        };
    </script>
</head>
<body>
    <h1>Login</h1>

    <div>
        <label>Email</label><br />
        <input id="email" type="email" />
    </div>

    <br />

    <div>
        <label>Password</label><br />
        <input id="password" type="password" />
    </div>

    <br />

    <button onclick="login()">
        Login
    </button>
</body>
</html>